# AdSense（実スロットIDは AdSense 管理画面の「広告ユニット」から）
# コピーして .env.local などに保存し、ビルド時に読み込む
# 詳細: ADSENSE_PLACEMENT_DESIGN.md / src/config/adsense.ts

# VITE_ADSENSE_SLOT_ARTICLE_TOP=1111111111
# VITE_ADSENSE_SLOT_IN_CONTENT=2222222222
# VITE_ADSENSE_SLOT_ARTICLE_BOTTOM=3333333333
# VITE_ADSENSE_SLOT_SIDEBAR=4444444444
# VITE_ADSENSE_SLOT_LISTING_FEED=5555555555
# VITE_ADSENSE_SLOT_ARTICLE_MID=6666666666
# VITE_ADSENSE_SLOT_ARTICLE_ANCHOR=7777777777

# 本文中広告（既定はオン）。オフにする場合: false
# VITE_ADSENSE_ENABLE_MID_ARTICLE=true
# VITE_ADSENSE_MID_ARTICLE_MIN_READING_MINUTES=8
# VITE_ADSENSE_MID_ARTICLE_MIN_H2=1

# 記事末アンカー（既定はオン）。オフにする場合: false
# VITE_ADSENSE_ENABLE_ANCHOR=true

# 本文直前バナーを試す場合のみ true（既定は CRO 優先でオフ）
# VITE_ADSENSE_ENABLE_ARTICLE_TOP=false

# 一覧・タグで N 件ごとにインフィード（4〜12、未指定時 9）
# VITE_ADSENSE_LISTING_FEED_EVERY=9

# 遅延ロード開始位置（IntersectionObserver rootMargin）
# VITE_ADSENSE_LAZY_ROOT_MARGIN=320px
